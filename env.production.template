# Backend (Express)
NODE_ENV=production
PORT=4000
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
# Run Prisma migrations on start (set false for multi-instance deploys)
RUN_MIGRATIONS_ON_START=true
# Optional HTTP server timeouts (ms)
# SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
# SERVER_HEADERS_TIMEOUT_MS=60000
# SERVER_REQUEST_TIMEOUT_MS=300000

# Database
#
# With docker-compose.prod.yml, DATABASE_URL is assembled from the three POSTGRES_*
# values below and REDIS_URL points at the bundled redis service — setting DATABASE_URL
# or REDIS_URL here has no effect in that setup. Only set them directly when running
# the backend outside compose, or when pointing at a managed database (in which case
# edit the compose environment block too).
POSTGRES_USER=bazi
# No default in compose: the stack refuses to start if this is empty.
POSTGRES_PASSWORD=change_this_to_a_long_random_password
POSTGRES_DB=bazi_master

# Only used outside docker-compose.prod.yml. MUST be PostgreSQL in production.
# DATABASE_URL=postgresql://user:password@host:5432/bazi_master?schema=public

# Host interfaces the published ports bind to. Loopback by default so nginx terminates
# TLS in front; set to 0.0.0.0 only if the host firewall is what protects these ports.
BACKEND_BIND_ADDR=127.0.0.1
FRONTEND_BIND_ADDR=127.0.0.1
BACKEND_MEMORY_LIMIT=1g
# Interface the Node process listens on *inside* the container. 0.0.0.0 is correct
# there — the container network is the boundary, and the host-side binding above is
# what actually controls exposure.
BIND_HOST=0.0.0.0

# Networking & CORS
# Base URL for the backend API
BACKEND_BASE_URL=https://api.yourdomain.com
# URL of the frontend application (for CORS and redirects)
FRONTEND_URL=https://app.yourdomain.com
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
# Trust proxy hops (set to 1 for a single reverse proxy)
TRUST_PROXY=1

# Session & Security
# MUST be set to a long random string (32+ chars)
SESSION_TOKEN_SECRET=change_this_to_a_secure_random_string_in_production
# Cookie settings (adjust SameSite to "none" when frontend/api are cross-site)
SESSION_COOKIE_SAMESITE=strict
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=
# Comma-separated list of admin emails
ADMIN_EMAILS=admin@yourdomain.com

# Redis (Caching & Session Store)
# REQUIRED for production to ensure consistent sessions/caching
REDIS_URL=redis://redis-host:6379

# AI Providers (optional)
# Set AI_PROVIDER to 'openai', 'anthropic' or 'mock'
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
AI_MAX_TOKENS=1000
AI_TIMEOUT_MS=20000

# Limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Tighter budget for credential endpoints (login/register/password), applied per source
# address and per targeted account.
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
# Request body ceiling. Raising this raises the memory a single request can consume.
JSON_BODY_LIMIT=1mb
MAX_URL_LENGTH=16384
# Input shape guards for JSON bodies
MAX_INPUT_ARRAY_LENGTH=1000
MAX_INPUT_DEPTH=10
MAX_INPUT_KEYS=200
MAX_INPUT_STRING_LENGTH=10000
# Rows per batch when importing records
IMPORT_BATCH_SIZE=500

# Timeouts & lifecycles (ms)
SESSION_IDLE_MS=1800000
RESET_TOKEN_TTL_MS=1800000
# Floor on password-reset request duration, to avoid leaking account existence by timing
RESET_REQUEST_MIN_DURATION_MS=350
SHUTDOWN_TIMEOUT_MS=10000
OAUTH_FETCH_TIMEOUT_MS=10000
REDIS_CONNECT_TIMEOUT_MS=3000

# Caching
BAZI_CACHE_TTL_MS=21600000
BAZI_CACHE_MAX_ENTRIES=500

# Logging
# trace | debug | info | warn | error | fatal. Raise to debug temporarily when
# investigating; production default is info.
LOG_LEVEL=info

# Documentation Security
# Username for API docs (Basic Auth). Defaults to 'admin' if not set.
DOCS_USER=admin
# Password for API docs (Basic Auth). REQUIRED in production if you want to access /api-docs.
DOCS_PASSWORD=secure_docs_password_change_me

# Auth/OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_SCOPE=snsapi_login
WECHAT_FRONTEND_URL=
WECHAT_REDIRECT_URI=

# Email (password reset)
PASSWORD_RESET_ENABLED=true
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="BaZi Master <no-reply@yourdomain.com>"
SMTP_REPLY_TO=
SMTP_TIMEOUT_MS=10000
PASSWORD_RESET_SUBJECT=

# Safety switches
# Ensure these are false in production
ALLOW_DEV_OAUTH=false
ALLOW_LOCALHOST_PROD=false
SEED_DEFAULT_USER=false
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
SEED_USER_NAME=
# Leave false. Lets the app create/alter tables at runtime instead of via migrations.
ALLOW_RUNTIME_SCHEMA_SYNC=false

# Sentry (Error Tracking)
SENTRY_DSN=
VITE_SENTRY_DSN=
# Distinguishes staging from production in the Sentry UI. Defaults to NODE_ENV.
SENTRY_ENVIRONMENT=production
# Deployment identifier (commit sha or tag). Without it an error cannot be tied to the
# release that introduced it, which is what a rollback decision rests on.
SENTRY_RELEASE=
# Fraction of requests traced. 1.0 will exhaust a small quota within days, after which
# real errors start getting dropped.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Profiling is expensive in both quota and CPU; leave at 0 unless investigating.
SENTRY_PROFILES_SAMPLE_RATE=0
